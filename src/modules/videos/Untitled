.discografia-section {
  width: 100%;
  min-height: 100vh;
  background-color: #e0e0de;
  display: flex;
  flex-direction: column;
  padding: 32px 40px 40px;
  box-sizing: border-box;
}

/* Título horizontal "discografía" (como en Novedades) */
.discografia-sidebar-title {
  font-family: 'Fraunces', Georgia, serif;
  font-size: 70px;
  font-weight: 400;
  color: #B89960;
  margin: 0 0 38px 0;
  padding: 0;
  letter-spacing: -0.05em;

}